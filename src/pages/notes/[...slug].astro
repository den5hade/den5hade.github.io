---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getRelatedPosts } from "../../utils/relatedPosts";

export async function getStaticPaths() {
  const posts = await getCollection("notes");
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const paramsSlug = Astro.params.slug;
const slug = Array.isArray(paramsSlug) ? paramsSlug.join("/") : paramsSlug;

const post = await getEntry("notes", slug);
if (!post) {
  throw new Error(`Notes entry not found: ${slug}`);
}

const { Content } = await render(post);
const baseUrl = import.meta.env.BASE_URL ?? "/";
const allPosts = await getCollection("notes");
const relatedPosts = getRelatedPosts(post.id, allPosts, 3);
---

<ContentLayout title={post.data.title}>
  <p style="margin: 0 0 18px;">
    <a href={`${baseUrl}notes/`}>← Back to notes</a>
  </p>

  <h1 style="margin-top: 0;">{post.data.title}</h1>
  <div style="color: var(--muted); font-size: 0.95rem; margin: 8px 0 22px;">
    <span>{post.data.date.toDateString()}</span>
    {post.data.tags?.length ? (
      <>
        {" • "}
        {post.data.tags.map((tag, index) => (
          <>
            <a href={`${baseUrl}notes/tag/${tag}/`} style="color: var(--link); text-decoration: none;">
              {tag}
            </a>
            {index < post.data.tags.length - 1 ? ", " : ""}
          </>
        ))}
      </>
    ) : ""}
  </div>

  <Content />

  {relatedPosts.length > 0 && (
    <div style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border);">
      <h3 style="margin: 0 0 16px;">Related notes</h3>
      <ul style="padding-left: 18px; margin: 0;">
        {relatedPosts.map((related) => (
          <li style="margin: 10px 0;">
            <a href={`${baseUrl}notes/${related.id}/`}>{related.data.title}</a>
            {related.data.tags?.length && (
              <div style="color: var(--muted); font-size: 0.85rem; margin-top: 4px;">
                {related.data.tags.map((tag, index) => (
                  <>
                    <a href={`${baseUrl}notes/tag/${tag}/`} style="color: var(--muted); text-decoration: none;">
                      {tag}
                    </a>
                    {index < related.data.tags.length - 1 ? ", " : ""}
                  </>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}
</ContentLayout>

