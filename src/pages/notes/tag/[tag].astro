---
import ContentLayout from "../../../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  
  // Extract all unique tags from notes
  const tags = new Set<string>();
  notes.forEach((note) => {
    note.data.tags?.forEach((tag) => tags.add(tag));
  });

  // Generate a route for each tag
  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const notes = await getCollection("notes");
const baseUrl = import.meta.env.BASE_URL ?? "/";

// Filter notes by tag and sort by date
const filteredNotes = notes
  .filter((note) => note.data.tags?.includes(tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<ContentLayout title={`Tag: ${tag}`}>
  <h1 style="margin: 0 0 12px;">Tag: {tag}</h1>
  <p style="margin: 0 0 24px; color: var(--muted); max-width: 64ch;">
    {filteredNotes.length}
    {filteredNotes.length === 1 ? "note" : "notes"} tagged with <em>{tag}</em>
  </p>

  {filteredNotes.length > 0 ? (
    <ul style="padding-left: 18px; margin: 0;">
      {filteredNotes.map((note) => (
        <li style="margin: 14px 0;">
          <a href={`${baseUrl}notes/${note.id}/`}>{note.data.title}</a>
          <div style="color: var(--muted); font-size: 0.9rem;">
            {note.data.date.toDateString()}
            {note.data.tags?.length ? ` • ${note.data.tags.join(", ")}` : ""}
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--muted);">No notes found with this tag.</p>
  )}

  <p style="margin-top: 32px;">
    <a href={`${baseUrl}notes/`}>← Back to notes</a>
  </p>
</ContentLayout>
