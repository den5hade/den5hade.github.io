---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

const blogEntries = await getCollection("blog");
const baseUrl = import.meta.env.BASE_URL ?? "/";

blogEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<ContentLayout title="Blog">
  <h1 style="margin: 0 0 12px;">Blog</h1>
  <p style="margin: 0 0 24px; color: var(--muted); max-width: 64ch;">
    Bigger write-ups: deployment walkthroughs, operational patterns, and code-first notes.
  </p>

  <ul style="padding-left: 18px; margin: 0;">
    {blogEntries.map((post) => (
      <li style="margin: 14px 0;">
        <a href={`${baseUrl}blog/${post.id}/`}>{post.data.title}</a>
        <div style="color: var(--muted); font-size: 0.9rem;">
          {post.data.date.toDateString()}
          {post.data.tags?.length ? (
            <>
              {" • "}
              {post.data.tags.map((tag, index) => (
                <>
                  <a href={`${baseUrl}blog/tag/${tag}/`} style="color: var(--link); text-decoration: none;">
                    {tag}
                  </a>
                  {index < post.data.tags.length - 1 ? ", " : ""}
                </>
              ))}
            </>
          ) : ""}
        </div>
      </li>
    ))}
  </ul>
</ContentLayout>

