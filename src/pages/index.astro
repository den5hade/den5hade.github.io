---
import ContentLayout from "../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

const blogEntries = await getCollection("blog");
const notesEntries = await getCollection("notes");

const baseUrl = import.meta.env.BASE_URL ?? "/";

blogEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
notesEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestBlog = blogEntries.slice(0, 2);
const latestNotes = notesEntries.slice(0, 3);
---

<ContentLayout title="Doerone">
  <h1 style="margin: 0 0 12px;">Doerone</h1>
  <p style="margin: 0 0 24px; color: var(--muted); max-width: 64ch;">
    Minimalist, typography-first DevOps knowledge base. Blog posts for bigger pieces,
    notes for small reusable patterns.
  </p>

  <section>
    <h2 style="margin-top: 28px;">Latest blog</h2>
    <ul style="padding-left: 18px; margin: 8px 0 0;">
      {latestBlog.map((post) => (
        <li>
          <a href={`${baseUrl}blog/${post.id}/`}>{post.data.title}</a>
          <div style="color: var(--muted); font-size: 0.9rem;">{post.data.date.toDateString()}</div>
        </li>
      ))}
    </ul>
    <p style="margin: 8px 0 0;">
      <a href={`${baseUrl}blog/`}>View all blog posts →</a>
    </p>
  </section>

  <hr />

  <section>
    <h2>Latest notes</h2>
    <ul style="padding-left: 18px; margin: 8px 0 0;">
      {latestNotes.map((note) => (
        <li>
          <a href={`${baseUrl}notes/${note.id}/`}>{note.data.title}</a>
          <div style="color: var(--muted); font-size: 0.9rem;">{note.data.date.toDateString()}</div>
        </li>
      ))}
    </ul>
    <p style="margin: 8px 0 0;">
      <a href={`${baseUrl}notes/`}>View all notes →</a>
    </p>
  </section>
</ContentLayout>

