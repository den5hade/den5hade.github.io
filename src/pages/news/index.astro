---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

const newsEntries = await getCollection("news");
const baseUrl = import.meta.env.BASE_URL ?? "/";

newsEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<ContentLayout title="News">
  <h1 style="margin: 0 0 12px;">News</h1>
  <p style="margin: 0 0 24px; color: var(--muted); max-width: 64ch;">
    Small reusable patterns: configs, command snippets, and operational gotchas.
  </p>

  <ul style="padding-left: 18px; margin: 0;">
    {newsEntries.map((news) => (
      <li style="margin: 14px 0;">
        <a href={`${baseUrl}news/${news.id}/`}>{news.data.title}</a>
        <div style="color: var(--muted); font-size: 0.9rem;">
          {news.data.date.toDateString()}
          {news.data.tags?.length ? (
            <>
              {" • "}
              {news.data.tags.map((tag, index) => (
                <>
                  <a href={`${baseUrl}news/tag/${tag}/`} style="color: var(--link); text-decoration: none;">
                    {tag}
                  </a>
                  {index < news.data.tags.length - 1 ? ", " : ""}
                </>
              ))}
            </>
          ) : ""}
        </div>
      </li>
    ))}
  </ul>
</ContentLayout>

