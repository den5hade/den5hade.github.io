---
import ContentLayout from "../../../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const news = await getCollection("news");
  
  // Extract all unique tags from news
  const tags = new Set<string>();
  news.forEach((item) => {
    item.data.tags?.forEach((tag) => tags.add(tag));
  });

  // Generate a route for each tag
  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const news = await getCollection("news");
const baseUrl = import.meta.env.BASE_URL ?? "/";

// Filter news by tag and sort by date
const filteredNews = news
  .filter((item) => item.data.tags?.includes(tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<ContentLayout title={`Tag: ${tag}`}>
  <h1 style="margin: 0 0 12px;">Tag: {tag}</h1>
  <p style="margin: 0 0 24px; color: var(--muted); max-width: 64ch;">
    {filteredNews.length}
    {filteredNews.length === 1 ? "news item" : "news items"} tagged with <em>{tag}</em>
  </p>

  {filteredNews.length > 0 ? (
    <ul style="padding-left: 18px; margin: 0;">
      {filteredNews.map((item) => (
        <li style="margin: 14px 0;">
          <a href={`${baseUrl}news/${item.id}/`}>{item.data.title}</a>
          <div style="color: var(--muted); font-size: 0.9rem;">
            {item.data.date.toDateString()}
            {item.data.tags?.length ? ` • ${item.data.tags.join(", ")}` : ""}
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--muted);">No news found with this tag.</p>
  )}

  <p style="margin-top: 32px;">
    <a href={`${baseUrl}news/`}>← Back to news</a>
  </p>
</ContentLayout>
