---
const brand = "doer";
const baseUrl = import.meta.env.BASE_URL ?? "/";
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={`${baseUrl}`} class="site-header__brand" aria-label="Go to home">
      {brand}
    </a>

    <a href={`${baseUrl}`} class="site-header__logo-link" aria-label="Go to home" tabindex="-1">
      <img src={`${baseUrl}doer_logo.png`} alt="doer logo" class="site-header__logo" />
    </a>

    <nav class="site-header__nav">
      <a href={`${baseUrl}blog/`} aria-label="Go to blog">Blog</a>
      <a href={`${baseUrl}notes/`} aria-label="Go to notes">Notes</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: 16px;
  }

  .site-header__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }

  .site-header__brand {
    font-weight: 700;
    font-size: 1.8rem;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
    justify-self: start;
  }

  .site-header__brand:hover {
    text-decoration: none;
    opacity: 0.75;
  }

  .site-header__logo-link {
    display: flex;
    justify-content: center;
    justify-self: center;
  }

  .site-header__logo {
    height: 144px;
    width: auto;
    display: block;
  }

  .site-header__nav {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: flex-end;
    justify-self: end;
    align-items: center;
  }

  @media (max-width: 480px) {
    .site-header__logo-link {
      display: none;
    }
  }
</style>
