---
const brand = "doer";
const baseUrl = import.meta.env.BASE_URL ?? "/";
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={`${baseUrl}`} class="site-header__logo-link" aria-label="Go to home" tabindex="-1">
      <img src={`${baseUrl}doer_logo.png`} alt="doer logo" class="site-header__logo" />
    </a>
  </div>
</header>

<style>
  .site-header {
    padding: 16px;
  }

  .site-header__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .site-header__logo-link {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .site-header__logo {
    height: 144px;
    width: auto;
    display: block;
  }

  @media (max-width: 480px) {
    .site-header__logo-link {
      display: none;
    }
  }
</style>
